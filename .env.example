# Mega Brain Environment Configuration
# Copy this file to .env and fill in your API keys

# === Required ===
# OpenAI API key (for GPT models and Whisper API)
OPENAI_API_KEY=sk-your-key-here

# === Optional (at least one required for full functionality) ===
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API key
GEMINI_API_KEY=your-key-here

# === Whisper STT ===
# Which Whisper model to use (tiny, base, small, medium, large)
WHISPER_MODEL=base
# Use OpenAI Whisper API instead of local model (true/false)
WHISPER_USE_API=false

# === Server ===
DASHBOARD_HOST=localhost
DASHBOARD_PORT=3001
